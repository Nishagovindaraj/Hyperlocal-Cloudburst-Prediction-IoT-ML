# Ignore Python virtual environment
myvenv/

# Ignore compiled Python files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore Jupyter/IPython checkpoints
.ipynb_checkpoints/

# Ignore model artifacts if not needed in repo
*.pkl

# Ignore Excel or other large datasets (optional)
*.xlsx
*.csv

# Ignore Arduino build artifacts
*.hex
*.elf
*.bin

# Keep Arduino source files (.ino) tracked
# Do NOT ignore *.ino

# Ignore VSCode/IDE configs
.vscode/
.idea/

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore logs and temp files
*.log
*.tmp